# === Configuration for AI Models ===
# Google Gemini API Key
GOOGLE_GENERATIVE_AI_API_KEY=""

# LLM Provider (Groq/OpenAI compatible)
OPENAI_BASE_URL="https://api.groq.com/openai/v1"
OPENAI_MODEL="meta-llama/llama-4-scout-17b-instruct"
OPENAI_KEY=""

# Reranker & Embeddings (Jina AI)
RERANK_BASE_URL="https://api.jina.ai/v1/rerank"
RERANK_MODEL="jina-reranker-v3"
RERANK_KEY=""

EMBEDDINGS_BASE_URL="https://api.jina.ai/v1"
EMBEDDINGS_MODEL="jina-embeddings-v5-text-small"
EMBEDDINGS_KEY=""

# === Authentication Configuration ===
# NextAuth
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="any_random_string_for_security"

# Google Login (OAuth 2.0)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OIDC Custom Provider (Optional)
OIDC_DOMAIN=""
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""

# === Database Configuration (PostgreSQL) ===
DB_USER="postgres"
DB_HOST="localhost"
DB_PASSWORD=""
DB_NAME="mes_assistant"
DB_PORT=5432

# === System Features ===
ENABLE_MEM0=true
ENABLE_VISION=true

# === Storage & Services ===
# Path to store physical documents
EXTERNAL_STORAGE_PATH="./external_storage"
FILE_SERVER_URL="/api/files"
NEXT_PUBLIC_FILE_SERVER_URL="/api/files"

# Service Ports
CHAT_SERVICE_PORT=8282
RAG_SERVICE_PORT=8000
RAG_SERVICE_URL="http://localhost:8000"
